# Local-first livestream capture stack
# Supports PUBLIC or otherwise AUTHORIZED sessions only.
# Do not use this stack to bypass DRM, logins, consent controls, or platform restrictions.

COMPOSE_PROJECT_NAME=thirdeye

# OpenClaw gateway access. The controller reads the token directly from
# ~/.openclaw/openclaw.json instead of storing it in this repo.
OPENCLAW_BASE_URL=http://127.0.0.1:18789
CONTROLLER_BASE_URL=http://127.0.0.1:8788
CONTROLLER_CORS_ORIGINS=http://127.0.0.1:1420,tauri://localhost

PUID=1000
PGID=1000
TZ=America/Chicago
DESKTOP_BASE_URL=http://127.0.0.1:8790
MACOS_CAPTURE_BASE_URL=http://127.0.0.1:8791

# Deepgram
DEEPGRAM_API_KEY=replace-me
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=
DEEPGRAM_DIARIZE=true
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_INTERIM_RESULTS=true
DEEPGRAM_VAD_EVENTS=true
DEEPGRAM_ENDPOINTING_MS=300
DEEPGRAM_UTTERANCE_END_MS=1000

# OpenClaw summaries
OPENCLAW_SUMMARY_MODEL=openai-codex/gpt-5.4
OPENCLAW_SUMMARY_TIMEOUT_SECONDS=60

# Capture defaults
RECORDING_FPS=15
RECORDING_WIDTH=1280
RECORDING_HEIGHT=720
MAX_DURATION_MINUTES=60
SILENCE_TIMEOUT_MINUTES=2
ENABLE_AUTO_STOP=false
LOG_LEVEL=INFO
FAKE_MODE=false
